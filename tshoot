# All chains and rules (verbose)
sudo iptables -L -n -v

# With line numbers (useful for deleting rules)
sudo iptables -L -n -v --line-numbers

# All tables
sudo iptables -t nat -L -n -v
sudo iptables -t filter -L -n -v
sudo iptables -t mangle -L -n -v

# Baseline (FortiGate / routing)
ping -c 2 10.0.1.1
nc -zv 10.0.1.1 3306

# DOCKER-USER only
sudo iptables -L DOCKER-USER -n -v --line-numbers

# INPUT (incoming)
sudo iptables -L INPUT -n -v --line-numbers

# FORWARD (through host)
sudo iptables -L FORWARD -n -v --line-numbers

# OUTPUT (outgoing)
sudo iptables -L OUTPUT -n -v --line-numbers


# List DOCKER-USER rules
sudo iptables -L DOCKER-USER -n -v --line-numbers

# Add ontario-api → 10.0.1.1
sudo iptables -I DOCKER-USER -s 172.21.0.0/16 -d 10.0.1.1 -j ACCEPT
sudo iptables -A DOCKER-USER -d 10.0.1.1 -j DROP

# Remove a rule by line number (e.g. line 1)
sudo iptables -D DOCKER-USER 1



# Config test
docker exec nginx-proxy nginx -t

# Reload
docker exec nginx-proxy nginx -s reload

# Check client IP nginx sees
curl -H "X-Forwarded-For: 1.2.3.4" https://api1.mycompany.com:10344/health


# Last 100 lines (access + error)
docker logs nginx-proxy --tail 100

# Follow logs live
docker logs nginx-proxy -f

# Last 200 lines, timestamps
docker logs nginx-proxy --tail 200 -t

# Lines that look like access log (IP at start)
docker logs nginx-proxy --tail 500 2>/dev/null | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+'

# Lines containing "/ontario/"
docker logs nginx-proxy --tail 1000 2>/dev/null | grep "/ontario/"

# Lines containing "/wildfire/"
docker logs nginx-proxy --tail 1000 2>/dev/null | grep "/wildfire/"

# Export last 1000 lines
docker logs nginx-proxy --tail 1000 > nginx-access.txt

# Split access vs error (if format allows)
docker logs nginx-proxy --tail 1000 2> nginx-error.txt 1> nginx-access.txt
